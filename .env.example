# ─── Database ─────────────────────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/task_manager

# ─── JWT Secrets ───────────────────────────────────────────────────────────────
# Use a long, random string in production (e.g. openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-a-different-random-secret

# ─── Token Expiry ─────────────────────────────────────────────────────────────
# Access token expires after 15 minutes (short-lived, rotate via /auth/refresh)
# Refresh token expires after 7 days (stored in DB, revoked on rotation)
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
